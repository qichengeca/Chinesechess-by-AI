<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="400dp"
    android:orientation="vertical"
    android:background="@drawable/dialog_bg"
    android:padding="0dp">

    <!-- 标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/colorPrimaryDark"
        android:paddingLeft="16dp"
        android:paddingRight="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="局域网联机"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>

    </RelativeLayout>

    <!-- 房间列表 -->
    <TextView
        android:id="@+id/lan_tv_scanning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="正在扫描房间..."
        android:textColor="@color/btnGold"
        android:textSize="14sp"
        android:padding="12dp"
        android:visibility="visible"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/lan_room_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <TextView
            android:id="@+id/lan_btn_back"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="返  回"
            android:textSize="15sp"
            android:textColor="@color/textDark"
            android:textStyle="bold"
            android:background="@drawable/btn_menu_bg"
            android:layout_marginRight="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/lan_btn_create"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="创建房间"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/btn_rematch_bg"
            android:layout_marginLeft="8dp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>